<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Продуктивность</title>
<script src="https://telegram.org/js/telegram-web-app.js"><\/script>
<link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@400;500&family=Manrope:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --accent: #3C3489; --accent-light: #EEEDFE; --accent-mid: #7F77DD;
  --teal: #1D9E75; --teal-light: #E1F5EE;
  --amber: #BA7517; --amber-light: #FAEEDA;
  --coral: #D85A30; --coral-light: #FAECE7;
  --bg: #FAFAF8; --bg2: #FFFFFF; --bg3: #F1EFE8;
  --text: #1a1a18; --text2: #888780; --text3: #B4B2A9;
  --border: rgba(0,0,0,0.08); --border2: rgba(0,0,0,0.14);
  --radius: 16px; --radius-sm: 10px;
}
body.tg-dark {
  --bg:#1a1a1f; --bg2:#232328; --bg3:#2c2c32;
  --text:#f0f0f0; --text2:#888888; --text3:#555555;
  --border:rgba(255,255,255,0.07); --border2:rgba(255,255,255,0.13);
  --accent-light:#26215C; --teal-light:#04342C; --amber-light:#412402; --coral-light:#4A1B0C;
}
html,body { height:100%; background:var(--bg); color:var(--text); font-family:'Manrope',sans-serif; font-size:16px; line-height:1.6; -webkit-font-smoothing:antialiased; overflow:hidden; }
.app { height:100%; display:flex; flex-direction:column; }
.nav-bar { display:flex; border-top:0.5px solid var(--border); background:var(--bg2); flex-shrink:0; padding:6px 0 12px; }
.nav-item { flex:1; display:flex; flex-direction:column; align-items:center; gap:3px; cursor:pointer; padding:6px 0; border:none; background:none; font-family:'Manrope',sans-serif; }
.nav-icon { font-size:22px; line-height:1; }
.nav-label { font-size:10px; color:var(--text2); }
.nav-item.active .nav-label { color:var(--accent); font-weight:600; }
.screens { flex:1; overflow:hidden; position:relative; }
.screen { position:absolute; inset:0; overflow-y:auto; overflow-x:hidden; scrollbar-width:none; opacity:0; pointer-events:none; transition:opacity 0.15s; }
.screen.active { opacity:1; pointer-events:all; }
.screen::-webkit-scrollbar { display:none; }
.page-header { padding:18px 16px 10px; position:sticky; top:0; background:var(--bg); z-index:5; border-bottom:0.5px solid var(--border); }
.header-row { display:flex; align-items:center; justify-content:space-between; margin-bottom:10px; }
.page-title { font-family:'Unbounded',sans-serif; font-size:18px; font-weight:500; color:var(--text); }
.header-btn { background:var(--bg3); border:none; border-radius:var(--radius-sm); padding:7px 12px; font-size:13px; font-family:'Manrope',sans-serif; color:var(--text2); cursor:pointer; }
.filters { display:flex; gap:6px; overflow-x:auto; scrollbar-width:none; padding-bottom:2px; }
.filters::-webkit-scrollbar { display:none; }
.filter-btn { white-space:nowrap; border:0.5px solid var(--border2); background:transparent; border-radius:99px; padding:5px 13px; font-size:13px; font-family:'Manrope',sans-serif; color:var(--text2); cursor:pointer; flex-shrink:0; }
.filter-btn.active { background:var(--accent); border-color:var(--accent); color:#fff; }
.list-wrap { padding:12px 16px; display:flex; flex-direction:column; gap:10px; }
.card { background:var(--bg2); border:0.5px solid var(--border); border-radius:var(--radius); padding:14px 16px; cursor:pointer; }
.card:active { opacity:0.8; }
.card-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:6px; }
.card-date { font-size:12px; color:var(--text3); }
.card-title { font-size:15px; font-weight:600; color:var(--text); margin-bottom:3px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.card-preview { font-size:13px; color:var(--text2); line-height:1.5; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
.tag { font-size:11px; font-weight:600; padding:3px 10px; border-radius:99px; }
.tag-diary { background:var(--teal-light); color:#085041; }
.tag-idea { background:var(--amber-light); color:#412402; }
.tag-summary { background:var(--coral-light); color:#4A1B0C; }
.tag-note { background:var(--accent-light); color:#26215C; }
.empty { text-align:center; padding:50px 20px; color:var(--text3); }
.empty-icon { font-size:44px; margin-bottom:10px; }
.empty-text { font-size:14px; line-height:1.6; }
.greeting { padding:20px 16px 0; }
.greeting-name { font-family:'Unbounded',sans-serif; font-size:19px; font-weight:500; color:var(--text); }
.greeting-date { font-size:13px; color:var(--text2); margin-top:2px; }
.stats-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; padding:14px 16px 0; }
.stat-card { background:var(--bg2); border:0.5px solid var(--border); border-radius:var(--radius); padding:14px; }
.stat-num { font-size:26px; font-weight:500; color:var(--text); }
.stat-label { font-size:12px; color:var(--text2); margin-top:2px; }
.section-label { font-size:11px; font-weight:600; color:var(--text2); text-transform:uppercase; letter-spacing:0.06em; padding:14px 16px 2px; }
.task-item { display:flex; align-items:flex-start; gap:10px; padding:10px 0; border-bottom:0.5px solid var(--border); cursor:pointer; }
.task-item:last-child { border-bottom:none; }
.task-check { width:20px; height:20px; border-radius:6px; border:1.5px solid var(--border2); flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:12px; color:#fff; margin-top:2px; }
.task-check.done { background:var(--teal); border-color:var(--teal); }
.task-text { font-size:14px; color:var(--text); flex:1; }
.task-text.done { text-decoration:line-through; color:var(--text3); }
.progress-bar { height:3px; background:var(--bg3); border-radius:99px; margin-top:8px; overflow:hidden; }
.progress-fill { height:100%; border-radius:99px; background:var(--teal); }
.cal-nav { display:flex; align-items:center; justify-content:space-between; padding:14px 16px 6px; }
.cal-month { font-size:15px; font-weight:600; color:var(--text); }
.cal-btn { background:var(--bg3); border:none; border-radius:8px; width:32px; height:32px; font-size:18px; cursor:pointer; color:var(--text); display:flex; align-items:center; justify-content:center; }
.cal-weekdays { display:grid; grid-template-columns:repeat(7,1fr); padding:0 10px; }
.cal-wd { text-align:center; font-size:11px; font-weight:600; color:var(--text2); padding:3px 0; }
.cal-grid { display:grid; grid-template-columns:repeat(7,1fr); padding:0 10px 6px; gap:2px; }
.cal-cell { aspect-ratio:1; display:flex; align-items:center; justify-content:center; font-size:13px; border-radius:10px; cursor:pointer; color:var(--text2); position:relative; }
.cal-cell.today { background:var(--accent); color:#fff; font-weight:600; }
.cal-cell.selected:not(.today) { background:var(--accent-light); color:var(--accent); font-weight:600; }
.cal-cell.has-dot::after { content:''; position:absolute; bottom:3px; left:50%; transform:translateX(-50%); width:4px; height:4px; border-radius:50%; background:var(--teal); }
.cal-cell.empty { pointer-events:none; }
.cal-day-label { padding:6px 16px 2px; font-size:13px; font-weight:600; color:var(--text2); }
.media-cover { width:46px; height:46px; border-radius:10px; background:var(--bg3); flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:22px; border:0.5px solid var(--border); }
.media-row { display:flex; gap:12px; align-items:center; }
.media-info { flex:1; min-width:0; }
.media-title { font-size:14px; font-weight:600; color:var(--text); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.media-sub { font-size:12px; color:var(--text2); margin-top:2px; }
.fab { position:fixed; bottom:80px; left:50%; transform:translateX(-50%); width:calc(100% - 32px); max-width:448px; background:var(--accent); color:#fff; border:none; border-radius:var(--radius); padding:15px; font-size:15px; font-weight:600; font-family:'Manrope',sans-serif; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:8px; box-shadow:0 4px 20px rgba(60,52,137,0.3); z-index:20; }
.fab:active { opacity:0.9; }
.fab.hidden { display:none; }
.overlay { position:fixed; inset:0; background:rgba(0,0,0,0.45); z-index:100; display:flex; align-items:flex-end; opacity:0; pointer-events:none; transition:opacity 0.2s; }
.overlay.open { opacity:1; pointer-events:all; }
.sheet { background:var(--bg2); border-radius:24px 24px 0 0; padding:16px 18px 36px; width:100%; transform:translateY(30px); transition:transform 0.22s ease; max-height:90vh; overflow-y:auto; }
.overlay.open .sheet { transform:translateY(0); }
.sheet-handle { width:36px; height:4px; background:var(--border2); border-radius:99px; margin:0 auto 16px; }
.sheet-title { font-family:'Unbounded',sans-serif; font-size:15px; font-weight:500; color:var(--text); margin-bottom:16px; }
.field { margin-bottom:13px; }
.field-label { font-size:11px; font-weight:600; color:var(--text2); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:5px; }
.tag-row { display:flex; gap:6px; flex-wrap:wrap; }
.tag-opt { border:0.5px solid var(--border2); border-radius:99px; padding:6px 13px; font-size:13px; font-family:'Manrope',sans-serif; cursor:pointer; background:transparent; color:var(--text2); }
.tag-opt.sel { background:var(--accent-light); border-color:var(--accent); color:#26215C; }
input[type=text],input[type=date],textarea { width:100%; background:var(--bg3); border:0.5px solid var(--border); border-radius:var(--radius-sm); padding:11px 13px; font-size:15px; font-family:'Manrope',sans-serif; color:var(--text); outline:none; resize:none; -webkit-appearance:none; }
input:focus,textarea:focus { border-color:var(--accent-mid); }
textarea { min-height:130px; line-height:1.6; }
.btn-row { display:flex; gap:10px; margin-top:16px; }
.btn-cancel { flex:1; background:var(--bg3); border:none; border-radius:var(--radius-sm); padding:13px; font-size:15px; font-family:'Manrope',sans-serif; color:var(--text2); cursor:pointer; }
.btn-save { flex:2; background:var(--accent); border:none; border-radius:var(--radius-sm); padding:13px; font-size:15px; font-weight:600; font-family:'Manrope',sans-serif; color:#fff; cursor:pointer; }
.detail { position:fixed; inset:0; background:var(--bg); z-index:50; display:flex; flex-direction:column; transform:translateX(100%); transition:transform 0.22s ease; }
.detail.open { transform:translateX(0); }
.detail-hdr { display:flex; align-items:center; gap:10px; padding:12px 16px; border-bottom:0.5px solid var(--border); flex-shrink:0; }
.back-btn { background:var(--bg3); border:none; border-radius:8px; width:36px; height:36px; font-size:18px; cursor:pointer; display:flex; align-items:center; justify-content:center; color:var(--text); flex-shrink:0; }
.detail-edit-btn { background:none; border:0.5px solid var(--border2); border-radius:8px; padding:6px 13px; font-size:13px; font-family:'Manrope',sans-serif; color:var(--text2); cursor:pointer; }
.detail-body { flex:1; overflow-y:auto; padding:22px 18px; }
.detail-title { font-family:'Unbounded',sans-serif; font-size:19px; font-weight:500; color:var(--text); margin-bottom:5px; line-height:1.3; }
.detail-date { font-size:13px; color:var(--text3); margin-bottom:18px; }
.detail-content { font-size:15px; line-height:1.8; color:var(--text); white-space:pre-wrap; }
</style>
</head>
<body>
<div class="app">
  <div class="screens">
    <div class="screen active" id="s-home">
      <div class="greeting">
        <div class="greeting-name" id="greetName">Добрый день 👋</div>
        <div class="greeting-date" id="greetDate"></div>
      </div>
      <div class="stats-grid">
        <div class="stat-card"><div class="stat-num" id="sNotes">0</div><div class="stat-label">заметок</div></div>
        <div class="stat-card"><div class="stat-num" id="sTasks">0</div><div class="stat-label">задач сегодня</div></div>
        <div class="stat-card"><div class="stat-num" id="sDone">0</div><div class="stat-label">выполнено</div></div>
        <div class="stat-card"><div class="stat-num" id="sMedia">0</div><div class="stat-label">медиа</div></div>
      </div>
      <div class="section-label">Задачи на сегодня</div>
      <div class="list-wrap" id="homeTasks"></div>
      <div class="section-label">Последние заметки</div>
      <div class="list-wrap" id="homeNotes"></div>
    </div>
    <div class="screen" id="s-notes">
      <div class="page-header">
        <div class="header-row">
          <div class="page-title">Заметки</div>
          <button class="header-btn" id="exportBtn">↓ .md</button>
        </div>
        <div class="filters" id="noteFilters">
          <button class="filter-btn active" data-filter="all">Все</button>
          <button class="filter-btn" data-filter="diary">📔 Дневник</button>
          <button class="filter-btn" data-filter="idea">💡 Идеи</button>
          <button class="filter-btn" data-filter="summary">🎧 Конспекты</button>
          <button class="filter-btn" data-filter="note">📝 Заметки</button>
        </div>
      </div>
      <div class="list-wrap" id="notesList"></div>
    </div>
    <div class="screen" id="s-calendar">
      <div class="cal-nav">
        <button class="cal-btn" id="calPrev">‹</button>
        <div class="cal-month" id="calMonth"></div>
        <button class="cal-btn" id="calNext">›</button>
      </div>
      <div class="cal-weekdays">
        <div class="cal-wd">Пн</div><div class="cal-wd">Вт</div><div class="cal-wd">Ср</div>
        <div class="cal-wd">Чт</div><div class="cal-wd">Пт</div><div class="cal-wd">Сб</div><div class="cal-wd">Вс</div>
      </div>
      <div class="cal-grid" id="calGrid"></div>
      <div class="cal-day-label" id="calDayLabel"></div>
      <div class="list-wrap" id="calTasks"></div>
    </div>
    <div class="screen" id="s-media">
      <div class="page-header">
        <div class="header-row"><div class="page-title">Медиа</div></div>
        <div class="filters" id="mediaFilters">
          <button class="filter-btn active" data-filter="all">Все</button>
          <button class="filter-btn" data-filter="podcast">🎙 Подкасты</button>
          <button class="filter-btn" data-filter="book">📚 Книги</button>
        </div>
      </div>
      <div class="list-wrap" id="mediaList"></div>
    </div>
  </div>
  <nav class="nav-bar">
    <button class="nav-item active" data-tab="home"><div class="nav-icon">🏠</div><div class="nav-label">Главная</div></button>
    <button class="nav-item" data-tab="notes"><div class="nav-icon">📝</div><div class="nav-label">Заметки</div></button>
    <button class="nav-item" data-tab="calendar"><div class="nav-icon">📅</div><div class="nav-label">Календарь</div></button>
    <button class="nav-item" data-tab="media"><div class="nav-icon">🎧</div><div class="nav-label">Медиа</div></button>
  </nav>
</div>

<button class="fab hidden" id="fab"><span style="font-size:20px">+</span> <span id="fabText">Добавить</span></button>

<div class="overlay" id="overlay">
  <div class="sheet">
    <div class="sheet-handle"></div>
    <div class="sheet-title" id="sheetTitle"></div>
    <div id="sheetBody"></div>
  </div>
</div>

<div class="detail" id="detail">
  <div class="detail-hdr">
    <button class="back-btn" id="detailBack">←</button>
    <span style="flex:1" id="detailTagEl"></span>
    <button class="detail-edit-btn" id="detailEditBtn">Изменить</button>
  </div>
  <div class="detail-body">
    <div class="detail-title" id="detailTitle"></div>
    <div class="detail-date" id="detailDate"></div>
    <div class="detail-content" id="detailContent"></div>
  </div>
</div>

<script>
var tg=window.Telegram&&window.Telegram.WebApp;
if(tg){tg.ready();tg.expand();}
if(tg&&tg.colorScheme==='dark')document.body.classList.add('tg-dark');

function load(k){try{return JSON.parse(localStorage.getItem(k)||'null');}catch(e){return null;}}
function save(k,v){localStorage.setItem(k,JSON.stringify(v));}

var notes=load('app_notes')||[];
var tasks=load('app_tasks')||[];
var media=load('app_media')||[];

if(!notes.length){
  notes=[
    {id:1,type:'diary',title:'Первый день',body:'Начинаю вести дневник. Сегодня попробовал новый подход к планированию — системы важнее целей.',date:new Date().toISOString()},
    {id:2,type:'idea',title:'90-минутные блоки',body:'Работать блоками по 90 минут без телефона. После каждого — 15 минут отдыха.',date:new Date(Date.now()-86400000).toISOString()},
    {id:3,type:'summary',title:'Huberman Lab — Сон',body:'- Утренний свет 30 мин\n- Кофеин убрать за 10 часов до сна\n- Одинаковый режим каждый день',date:new Date(Date.now()-172800000).toISOString()},
  ];
  save('app_notes',notes);
}
if(!tasks.length){
  tasks=[
    {id:1,title:'Послушать подкаст',done:false,date:today()},
    {id:2,title:'Записать идеи в дневник',done:true,date:today()},
    {id:3,title:'Прочитать главу книги',done:false,date:today()},
  ];
  save('app_tasks',tasks);
}
if(!media.length){
  media=[
    {id:1,type:'podcast',title:'Huberman Lab #112',sub:'YouTube · 2ч 14м',icon:'🎙',progress:62},
    {id:2,type:'book',title:'Война и мир',sub:'LibriVox · Толстой',icon:'📚',progress:8},
  ];
  save('app_media',media);
}

function today(){return new Date().toISOString().slice(0,10);}
function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function fmtDate(iso){
  var d=new Date(iso),now=new Date();
  if(now.toDateString()===d.toDateString())return'Сегодня, '+d.toLocaleTimeString('ru',{hour:'2-digit',minute:'2-digit'});
  var y=new Date(now);y.setDate(y.getDate()-1);
  if(y.toDateString()===d.toDateString())return'Вчера';
  return d.toLocaleDateString('ru',{day:'numeric',month:'long'});
}
function fmtLong(iso){return new Date(iso).toLocaleString('ru',{day:'numeric',month:'long',hour:'2-digit',minute:'2-digit'});}
var TL={diary:'Дневник',idea:'Идея',summary:'Конспект',note:'Заметка'};
var TE={diary:'📔',idea:'💡',summary:'🎧',note:'📝'};
function tagHTML(t){return'<span class="tag tag-'+t+'">'+TE[t]+' '+TL[t]+'</span>';}

var currentTab='home';
var editingNoteId=null;
var viewingNoteId=null;
var selectedTag='note';
var selectedMediaType='podcast';
var calYear,calMonth,calSelected;

// Навигация
document.querySelectorAll('.nav-item').forEach(function(btn){
  btn.addEventListener('click',function(){switchTab(btn.dataset.tab);});
});

function switchTab(tab){
  currentTab=tab;
  document.querySelectorAll('.screen').forEach(function(s){s.classList.remove('active');});
  document.querySelectorAll('.nav-item').forEach(function(n){n.classList.remove('active');});
  document.getElementById('s-'+tab).classList.add('active');
  document.querySelector('.nav-item[data-tab="'+tab+'"]').classList.add('active');
  var fab=document.getElementById('fab');
  var fabText=document.getElementById('fabText');
  if(tab==='home'){fab.classList.add('hidden');renderHome();}
  else if(tab==='notes'){fab.classList.remove('hidden');fabText.textContent='Новая заметка';renderNotes();}
  else if(tab==='calendar'){fab.classList.remove('hidden');fabText.textContent='Новая задача';renderCalendar();}
  else if(tab==='media'){fab.classList.remove('hidden');fabText.textContent='Добавить медиа';renderMedia();}
}

document.getElementById('fab').addEventListener('click',openAdd);

// ГЛАВНАЯ
function renderHome(){
  var user=tg&&tg.initDataUnsafe&&tg.initDataUnsafe.user;
  var name=user?user.first_name:'';
  var h=new Date().getHours();
  var gr=h<12?'Доброе утро':h<18?'Добрый день':'Добрый вечер';
  document.getElementById('greetName').textContent=gr+(name?', '+name:'')+' 👋';
  var now=new Date();
  var days=['воскресенье','понедельник','вторник','среда','четверг','пятница','суббота'];
  var dn=days[now.getDay()];
  document.getElementById('greetDate').textContent=dn[0].toUpperCase()+dn.slice(1)+', '+now.toLocaleDateString('ru',{day:'numeric',month:'long'});
  var td=tasks.filter(function(t){return t.date===today();});
  document.getElementById('sNotes').textContent=notes.length;
  document.getElementById('sTasks').textContent=td.length;
  document.getElementById('sDone').textContent=td.filter(function(t){return t.done;}).length;
  document.getElementById('sMedia').textContent=media.length;
  var ht=document.getElementById('homeTasks');
  if(!td.length){ht.innerHTML='<div class="empty"><div class="empty-icon">✅</div><div class="empty-text">Задач нет.<br>Перейди в Календарь чтобы добавить</div></div>';}
  else{
    ht.innerHTML='<div class="card">'+td.map(function(t){return'<div class="task-item" data-id="'+t.id+'"><div class="task-check'+(t.done?' done':'')+'>'+(t.done?'✓':'')+'</div><div class="task-text'+(t.done?' done':'')+'">'+esc(t.title)+'</div></div>';}).join('')+'</div>';
    ht.querySelectorAll('.task-item').forEach(function(el){el.addEventListener('click',function(){toggleTask(+el.dataset.id);});});
  }
  var hn=document.getElementById('homeNotes');
  var recent=[].concat(notes).sort(function(a,b){return new Date(b.date)-new Date(a.date);}).slice(0,3);
  if(!recent.length){hn.innerHTML='<div class="empty"><div class="empty-icon">📓</div><div class="empty-text">Заметок нет</div></div>';}
  else{hn.innerHTML=recent.map(noteCardHTML).join('');hn.querySelectorAll('.card[data-id]').forEach(function(el){el.addEventListener('click',function(){openNote(+el.dataset.id);});});}
}

// ЗАМЕТКИ
var noteFilter='all';
document.getElementById('noteFilters').addEventListener('click',function(e){
  var btn=e.target.closest('.filter-btn');if(!btn)return;
  noteFilter=btn.dataset.filter;
  document.querySelectorAll('#noteFilters .filter-btn').forEach(function(b){b.classList.remove('active');});
  btn.classList.add('active');renderNotes();
});
document.getElementById('exportBtn').addEventListener('click',exportMd);

function noteCardHTML(n){
  return'<div class="card" data-id="'+n.id+'"><div class="card-top">'+tagHTML(n.type)+'<span class="card-date">'+fmtDate(n.date)+'</span></div><div class="card-title">'+esc(n.title)+'</div><div class="card-preview">'+esc(n.body)+'</div></div>';
}
function renderNotes(){
  var list=document.getElementById('notesList');
  var filtered=noteFilter==='all'?notes:notes.filter(function(n){return n.type===noteFilter;});
  var sorted=[].concat(filtered).sort(function(a,b){return new Date(b.date)-new Date(a.date);});
  if(!sorted.length){list.innerHTML='<div class="empty"><div class="empty-icon">📓</div><div class="empty-text">Заметок нет.<br>Нажми «+» чтобы добавить</div></div>';return;}
  list.innerHTML=sorted.map(noteCardHTML).join('');
  list.querySelectorAll('.card[data-id]').forEach(function(el){el.addEventListener('click',function(){openNote(+el.dataset.id);});});
}
function openNote(id){
  viewingNoteId=id;
  var n=notes.find(function(x){return x.id===id;});if(!n)return;
  document.getElementById('detailTitle').textContent=n.title;
  document.getElementById('detailDate').textContent=fmtLong(n.date);
  document.getElementById('detailContent').textContent=n.body;
  document.getElementById('detailTagEl').innerHTML=tagHTML(n.type);
  document.getElementById('detail').classList.add('open');
}
document.getElementById('detailBack').addEventListener('click',function(){document.getElementById('detail').classList.remove('open');viewingNoteId=null;});
document.getElementById('detailEditBtn').addEventListener('click',function(){var id=viewingNoteId;document.getElementById('detail').classList.remove('open');setTimeout(function(){openNoteSheet(id);},250);});

function openNoteSheet(id){
  var n=id?notes.find(function(x){return x.id===id;}):null;
  editingNoteId=id||null;selectedTag=n?n.type:'note';
  openSheet(id?'Изменить заметку':'Новая заметка',buildNoteForm(n));
}
function buildNoteForm(n){
  var types=[{k:'note',l:'📝 Заметка'},{k:'diary',l:'📔 Дневник'},{k:'idea',l:'💡 Идея'},{k:'summary',l:'🎧 Конспект'}];
  return'<div class="field"><div class="field-label">Тип</div><div class="tag-row" id="tagRow">'+types.map(function(t){return'<button class="tag-opt'+(selectedTag===t.k?' sel':'')+'" data-tag="'+t.k+'">'+t.l+'</button>';}).join('')+'</div></div>'
    +'<div class="field"><div class="field-label">Заголовок</div><input type="text" id="fTitle" placeholder="Название..." value="'+esc(n?n.title:'')+'"></div>'
    +'<div class="field"><div class="field-label">Текст</div><textarea id="fBody" placeholder="Пиши здесь...">'+esc(n?n.body:'')+'</textarea></div>'
    +'<div class="btn-row"><button class="btn-cancel" id="sheetCancel">Отмена</button><button class="btn-save" id="sheetSave">Сохранить</button></div>';
}
function saveNote(){
  var title=(document.getElementById('fTitle').value||'').trim()||'Без заголовка';
  var body=(document.getElementById('fBody').value||'').trim();
  if(!body){document.getElementById('fBody').focus();return;}
  if(editingNoteId){var n=notes.find(function(x){return x.id===editingNoteId;});if(n)Object.assign(n,{title:title,body:body,type:selectedTag,date:new Date().toISOString()});editingNoteId=null;}
  else{notes.push({id:Date.now(),type:selectedTag,title:title,body:body,date:new Date().toISOString()});}
  save('app_notes',notes);closeSheet();renderNotes();renderHome();
}
function exportMd(){
  if(!notes.length){alert('Нет заметок');return;}
  var md=[].concat(notes).sort(function(a,b){return new Date(b.date)-new Date(a.date);}).map(function(n){return'# '+n.title+'\n\n**Тип:** '+TL[n.type]+'  \n**Дата:** '+fmtLong(n.date)+'\n\n'+n.body+'\n\n---';}).join('\n\n');
  var a=document.createElement('a');a.href=URL.createObjectURL(new Blob([md],{type:'text/markdown'}));a.download='заметки.md';a.click();
}

// ЗАДАЧИ
function toggleTask(id){
  var t=tasks.find(function(x){return x.id===id;});if(!t)return;
  t.done=!t.done;save('app_tasks',tasks);renderHome();
  if(currentTab==='calendar')renderDayTasks();
}

// КАЛЕНДАРЬ
function renderCalendar(){
  var now=new Date();
  if(calYear===undefined){calYear=now.getFullYear();calMonth=now.getMonth();}
  if(!calSelected)calSelected=today();
  var months=['Январь','Февраль','Март','Апрель','Май','Июнь','Июль','Август','Сентябрь','Октябрь','Ноябрь','Декабрь'];
  document.getElementById('calMonth').textContent=months[calMonth]+' '+calYear;
  var first=new Date(calYear,calMonth,1);
  var startDay=first.getDay()-1;if(startDay<0)startDay=6;
  var total=new Date(calYear,calMonth+1,0).getDate();
  var todayISO=today();
  var html='';
  for(var i=0;i<startDay;i++)html+='<div class="cal-cell empty"></div>';
  for(var d=1;d<=total;d++){
    var ds=calYear+'-'+String(calMonth+1).padStart(2,'0')+'-'+String(d).padStart(2,'0');
    var cls='cal-cell'+(ds===todayISO?' today':'')+(ds===calSelected&&ds!==todayISO?' selected':'')+(tasks.some(function(t){return t.date===ds;})?' has-dot':'');
    html+='<div class="'+cls+'" data-date="'+ds+'">'+d+'</div>';
  }
  var grid=document.getElementById('calGrid');
  grid.innerHTML=html;
  grid.querySelectorAll('.cal-cell[data-date]').forEach(function(el){el.addEventListener('click',function(){calSelected=el.dataset.date;renderCalendar();});});
  renderDayTasks();
}
function renderDayTasks(){
  var d=new Date(calSelected+'T12:00:00');
  var label=d.toLocaleDateString('ru',{weekday:'long',day:'numeric',month:'long'});
  document.getElementById('calDayLabel').textContent=label[0].toUpperCase()+label.slice(1);
  var dayTasks=tasks.filter(function(t){return t.date===calSelected;});
  var ct=document.getElementById('calTasks');
  if(!dayTasks.length){ct.innerHTML='<div class="empty"><div class="empty-text">Задач нет. Нажми «+» чтобы добавить</div></div>';return;}
  ct.innerHTML='<div class="card">'+dayTasks.map(function(t){return'<div class="task-item" data-id="'+t.id+'"><div class="task-check'+(t.done?' done':'')+'>'+(t.done?'✓':'')+'</div><div class="task-text'+(t.done?' done':'')+'">'+esc(t.title)+'</div></div>';}).join('')+'</div>';
  ct.querySelectorAll('.task-item').forEach(function(el){el.addEventListener('click',function(){toggleTask(+el.dataset.id);renderDayTasks();});});
}
document.getElementById('calPrev').addEventListener('click',function(){calMonth--;if(calMonth<0){calMonth=11;calYear--;}renderCalendar();});
document.getElementById('calNext').addEventListener('click',function(){calMonth++;if(calMonth>11){calMonth=0;calYear++;}renderCalendar();});

function buildTaskForm(){
  return'<div class="field"><div class="field-label">Задача</div><input type="text" id="fTitle" placeholder="Что нужно сделать?"></div>'
    +'<div class="field"><div class="field-label">Дата</div><input type="date" id="fDate" value="'+(calSelected||today())+'"></div>'
    +'<div class="btn-row"><button class="btn-cancel" id="sheetCancel">Отмена</button><button class="btn-save" id="sheetSave">Сохранить</button></div>';
}
function saveTask(){
  var title=(document.getElementById('fTitle').value||'').trim();
  var date=document.getElementById('fDate').value||today();
  if(!title){document.getElementById('fTitle').focus();return;}
  tasks.push({id:Date.now(),title:title,done:false,date:date});
  save('app_tasks',tasks);closeSheet();renderCalendar();renderHome();
}

// МЕДИА
var mediaFilter='all';
document.getElementById('mediaFilters').addEventListener('click',function(e){
  var btn=e.target.closest('.filter-btn');if(!btn)return;
  mediaFilter=btn.dataset.filter;
  document.querySelectorAll('#mediaFilters .filter-btn').forEach(function(b){b.classList.remove('active');});
  btn.classList.add('active');renderMedia();
});
function renderMedia(){
  var list=document.getElementById('mediaList');
  var filtered=mediaFilter==='all'?media:media.filter(function(m){return m.type===mediaFilter;});
  if(!filtered.length){list.innerHTML='<div class="empty"><div class="empty-icon">🎧</div><div class="empty-text">Нет медиа.<br>Нажми «+» чтобы добавить</div></div>';return;}
  list.innerHTML=filtered.map(function(m){return'<div class="card"><div class="media-row"><div class="media-cover">'+(m.icon||'🎧')+'</div><div class="media-info"><div class="media-title">'+esc(m.title)+'</div><div class="media-sub">'+esc(m.sub||'')+'</div></div><span class="tag '+(m.type==='podcast'?'tag-summary':'tag-note')+'">'+(m.type==='podcast'?'Подкаст':'Книга')+'</span></div>'+(m.progress!=null?'<div class="progress-bar"><div class="progress-fill" style="width:'+m.progress+'%"></div></div>':'')+'</div>';}).join('');
}
function buildMediaForm(){
  selectedMediaType='podcast';
  return'<div class="field"><div class="field-label">Тип</div><div class="tag-row" id="tagRow"><button class="tag-opt sel" data-tag="podcast">🎙 Подкаст</button><button class="tag-opt" data-tag="book">📚 Аудиокнига</button></div></div>'
    +'<div class="field"><div class="field-label">Название</div><input type="text" id="fTitle" placeholder="Название..."></div>'
    +'<div class="field"><div class="field-label">Ссылка</div><input type="text" id="fUrl" placeholder="https://..."></div>'
    +'<div class="btn-row"><button class="btn-cancel" id="sheetCancel">Отмена</button><button class="btn-save" id="sheetSave">Добавить</button></div>';
}
function saveMedia(){
  var title=(document.getElementById('fTitle').value||'').trim();
  if(!title){document.getElementById('fTitle').focus();return;}
  var url=(document.getElementById('fUrl').value||'').trim();
  media.push({id:Date.now(),type:selectedMediaType,title:title,sub:url||(selectedMediaType==='podcast'?'YouTube':'LibriVox'),icon:selectedMediaType==='podcast'?'🎙':'📚',progress:0});
  save('app_media',media);closeSheet();renderMedia();renderHome();
}

// МОДАЛЬНОЕ ОКНО
function openSheet(title,bodyHTML){
  document.getElementById('sheetTitle').textContent=title;
  document.getElementById('sheetBody').innerHTML=bodyHTML;
  document.getElementById('overlay').classList.add('open');
  // Кнопки формы
  var cancel=document.getElementById('sheetCancel');
  var saveBtn=document.getElementById('sheetSave');
  if(cancel)cancel.addEventListener('click',closeSheet);
  if(saveBtn)saveBtn.addEventListener('click',function(){
    if(currentTab==='notes'||editingNoteId)saveNote();
    else if(currentTab==='calendar')saveTask();
    else if(currentTab==='media')saveMedia();
  });
  // Теги заметки
  var tagRow=document.getElementById('tagRow');
  if(tagRow){
    tagRow.addEventListener('click',function(e){
      var btn=e.target.closest('.tag-opt');if(!btn)return;
      if(currentTab==='media'||(!editingNoteId&&currentTab!=='notes')){selectedMediaType=btn.dataset.tag;}
      else{selectedTag=btn.dataset.tag;}
      tagRow.querySelectorAll('.tag-opt').forEach(function(b){b.classList.remove('sel');});
      btn.classList.add('sel');
    });
  }
}
function closeSheet(){document.getElementById('overlay').classList.remove('open');editingNoteId=null;}
document.getElementById('overlay').addEventListener('click',function(e){if(e.target===document.getElementById('overlay'))closeSheet();});

function openAdd(){
  if(currentTab==='notes')openNoteSheet(null);
  else if(currentTab==='calendar')openSheet('Новая задача',buildTaskForm());
  else if(currentTab==='media')openSheet('Добавить медиа',buildMediaForm());
}

renderHome();
</script>
</body>
</html>
